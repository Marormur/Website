{
  "name": "website",
  "version": "1.0.0",
  "description": "Eine persönliche Portfolio‑Website mit Desktop‑Metapher: Fenster, Modale und Menüleiste im macOS‑Look, Dark Mode, Mehrsprachigkeit (DE/EN) und ein integrierter Projekte‑Browser, der öffentliche GitHub‑Repos lädt. Zusätzlich enthält die Seite einen einfachen Texteditor und einen Bildbetrachter.",
  "main": "app.js",
  "scripts": {
    "build:css": "cross-env NODE_ENV=production postcss src/input.css -o dist/output.css",
    "build:css:dev": "postcss src/input.css -o dist/output.css",
    "watch:css": "cross-env NODE_OPTIONS=--max-old-space-size=8192 postcss src/input.css -o dist/output.css --watch",
    "dev": "node server.js",
    "pw:install": "playwright install",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:chromium": "playwright test --project=chromium",
    "test:e2e:all-browsers": "cross-env CI=1 playwright test",
    "test:e2e:quick": "playwright test --grep basic --project=chromium",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:unit:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "test:coverage:watch": "vitest --coverage",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "typecheck:watch": "cross-env NODE_OPTIONS=--max-old-space-size=2048 tsc --noEmit -p tsconfig.json --watch --incremental",
    "type:report": "type-coverage --detail",
    "type:baseline": "type-coverage --at-least 77",
    "type:coverage": "type-coverage --at-least 90 --detail",
    "build:ts": "tsc -p tsconfig.tsbuild.json",
    "build:ts:watch": "tsc -p tsconfig.tsbuild.json --watch",
    "build:bundle": "node scripts/build-esbuild.mjs",
    "dev:bundle": "node scripts/build-esbuild.mjs --watch",
    "lint": "eslint --quiet \"src/ts/**/*.ts\"",
    "lint:fix": "eslint --fix \"src/ts/**/*.ts\"",
    "format": "prettier --write \"**/*.{js,css,html,md,json}\"",
    "format:check": "prettier --check \"**/*.{js,css,html,md,json}\"",
    "validate": "npm run typecheck && npm run type:baseline && npm run build:ts && npm run lint && npm run build:css && npm run test:e2e",
    "validate:vdom": "node scripts/validate-vdom-performance.js",
    "docs:clean": "rimraf docs/api",
    "docs:generate": "typedoc",
    "docs:serve": "npx serve docs/api",
    "docs:watch": "typedoc --watch",
    "clean:legacy": "rimraf js/legacy",
    "knip": "knip --production",
    "knip:report": "knip --production --reporter json > knip-report.json",
    "lighthouse": "lhci collect --config=lighthouserc.json",
    "lighthouse:upload": "lhci upload",
    "lighthouse:ci": "lhci autorun --config=lighthouserc.json",
    "bundle:analyze": "node scripts/analyze-bundle.mjs",
    "turbo:build": "turbo run build:css build:ts build:bundle --cache-repo=.turbo",
    "turbo:lint": "turbo run lint typecheck --cache-repo=.turbo",
    "turbo:validate": "turbo run validate --cache-repo=.turbo",
    "turbo:watch": "turbo run watch:css typecheck:watch dev:bundle --parallel",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.js": [
      "eslint --fix --ignore-pattern 'js/**/*.js'",
      "prettier --write"
    ],
    "src/ts/**/*.ts": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{css,md,html,json}": [
      "prettier --write"
    ]
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Marormur/Website.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/Marormur/Website/issues"
  },
  "homepage": "https://github.com/Marormur/Website#readme",
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.4",
    "@eslint/js": "^10.0.0",
    "@lhci/cli": "^0.15.1",
    "@playwright/test": "^1.57.0",
    "@tailwindcss/postcss": "^4.2.1",
    "@types/node": "^25.0.0",
    "@typescript-eslint/eslint-plugin": "^8.49.0",
    "@typescript-eslint/parser": "^8.49.0",
    "@vitest/coverage-v8": "^4.0.18",
    "@vitest/ui": "^4.0.18",
    "autoprefixer": "^10.4.27",
    "chokidar": "^5.0.0",
    "cross-env": "^10.1.0",
    "esbuild": "^0.27.1",
    "esbuild-bundle-analyzer": "^0.0.1",
    "eslint": "^10.0.0",
    "husky": "^9.1.7",
    "jsdom": "^26.0.0",
    "knip": "^5.75.1",
    "lint-staged": "^16.2.7",
    "postcss": "^8.5.8",
    "postcss-cli": "^11.0.1",
    "prettier": "^3.7.4",
    "rimraf": "^6.1.2",
    "tailwindcss": "^4.2.1",
    "turbo": "^2.6.3",
    "type-coverage": "^2.29.7",
    "typedoc": "^0.28.17",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "overrides": {
    "tmp": "^0.2.4"
  }
}
